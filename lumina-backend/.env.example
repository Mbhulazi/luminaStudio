# ── Server ──
PORT=4000
NODE_ENV=development
# Comma-separated list of origins allowed to call this API (your frontend URL(s))
CORS_ORIGIN=http://localhost:3000,https://your-frontend-domain.com
# Your frontend's public base URL — used for email verification / reset links
APP_BASE_URL=http://localhost:3000
# Log level: trace | debug | info | warn | error
LOG_LEVEL=debug

# ── Database ──
# Postgres connection string. Works with Render, Railway, Supabase, Neon, or
# a local Postgres instance. Format:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# Supabase (eu-west-1) via the SESSION-mode pooler — port 5432, IPv4-friendly.
# A single URL that works for both the runtime app and `prisma migrate dev`.
# Replace [YOUR-SUPABASE-DB-PASSWORD] with your project's database password.
DATABASE_URL=postgresql://postgres.pppiquczkedsmbdrshrm:[YOUR-SUPABASE-DB-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
# --- Transaction-pooler upgrade (optional, for higher concurrency) ---
# Swap DATABASE_URL to port 6543 + pgbouncer=true, and uncomment DIRECT_URL
# plus the `directUrl` line in prisma/schema.prisma. The CLI uses DIRECT_URL
# (5432, session mode) for migrations; the app uses DATABASE_URL (6543,
# transaction mode) at runtime.
# DATABASE_URL="postgresql://postgres.pppiquczkedsmbdrshrm:[YOUR-SUPABASE-DB-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.pppiquczkedsmbdrshrm:[YOUR-SUPABASE-DB-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ── Auth ──
# Generate a long random string for production, e.g.: openssl rand -hex 32
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ── Currency ──
# USD is the standard/base currency for all plan prices stored in the DB.
# This is a fixed *demo* rate used to display ZAR estimates. For production,
# swap currency.service.js to call a real FX API (e.g. exchangerate.host,
# Open Exchange Rates) and cache the result for a few hours.
USD_TO_ZAR_FALLBACK_RATE=18.50

# ── PayFast (South Africa) ──
# Get these from your PayFast merchant dashboard: https://www.payfast.co.za
# Sandbox credentials for testing: merchant_id=10000100, merchant_key=46f0cd694581a
PAYFAST_MODE=sandbox
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
# Passphrase is set by YOU in the PayFast dashboard under Settings > Security.
# Leave blank only if you have not set one (not recommended for production).
PAYFAST_PASSPHRASE=
# Where PayFast redirects the shopper after payment (your frontend pages)
PAYFAST_RETURN_URL=http://localhost:3000/checkout?status=success
PAYFAST_CANCEL_URL=http://localhost:3000/checkout?status=cancelled
# Where PayFast sends the server-to-server Instant Transaction Notification.
# Must be a publicly reachable URL pointing at this backend.
PAYFAST_NOTIFY_URL=https://your-backend-domain.com/api/payments/payfast/itn
# How long to cache DNS-resolved PayFast source IPs (ms). Default 6h.
PAYFAST_IP_TTL_MS=21600000

# ── International card payments (USD, outside South Africa) ──
# PayFast settles in ZAR only. For USD-denominated card payments from
# customers outside South Africa, plug in a second provider such as Stripe
# here, and implement its provider class alongside PayFastProvider in
# src/services/payfast.service.js's sibling module.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Transactional email ──
# Driver: log (dev) | smtp | resend
EMAIL_DRIVER=log
EMAIL_FROM_NAME=Lummina Studio
EMAIL_FROM_ADDRESS=no-reply@luminastudio.art
# SMTP (e.g. Amazon SES, Mailgun, Postmark, Resend SMTP relay):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Resend HTTP API (alternative to SMTP):
RESEND_API_KEY=

# ── Image storage (Phase 2) ──
# Driver: local (dev) | supabase
STORAGE_DRIVER=local
# Local storage directory (relative to project root) — files served from /uploads
STORAGE_LOCAL_DIR=./uploads
# Supabase project:
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=portraits

# ── LLM analysis interpreter (Phase 3) ──
# Driver: template (offline, deterministic) | openai | anthropic
LLM_DRIVER=template
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Hard cost ceiling per analysis in USD cents (safety; analysis aborts if exceeded)
LLM_MAX_COST_CENTS=50

# ── Test mode ──
# Forces offline/deterministic behaviour. Set by the Vitest bootstrap.
IS_TEST=false
