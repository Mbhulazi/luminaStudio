# ============================================================================
# Root .gitignore for Lumina Studio monorepo
# Covers both app/ (Next.js frontend) and lumina-backend/ (Node/Express).
# Sub-projects have their own .gitignore too; this is the catch-all.
# ============================================================================

# ── Dependencies ──
node_modules/
**/node_modules/

# ── Build output ──
.next/
out/
dist/
build/
**/.next/
**/dist/
**/build/

# ── Test / coverage artifacts ──
test-results/
**/test-results/
playwright-report/
coverage/
.nyc_output/

# ── TypeScript build cache ──
*.tsbuildinfo

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Environment & secrets (NEVER commit) ──
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
*.pem
*.key
secrets/

# ── Secrets-manager workflow artifacts (NEVER commit) ──
# Pre-scrub backups from scrub-secrets.sh still hold real secret values.
*.pre-scrub.*.bak
**/*.pre-scrub.*.bak
# Doppler local token cache (written by `doppler login`)
.doppler/

# ── Uploaded user content (portraits) — private, never commit ──
uploads/
**/uploads/
uploads-test/
**/uploads-test/

# ── Local dev databases ──
prisma/dev.db
**/prisma/dev.db

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~
